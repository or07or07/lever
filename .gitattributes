# Normalize all text files to LF in the repo, check out as LF everywhere
* text=auto eol=lf

# Ensure these are always treated as text
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.env* text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

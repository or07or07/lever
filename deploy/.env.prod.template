# =============================================================================
# Lever — Production Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.prod.template .env.prod
#   2. Fill in ALL values marked CHANGE_ME
#   3. NEVER commit .env.prod to git
#   4. Set file permissions:  chmod 600 .env.prod
#
# Generate strong secrets:
#   openssl rand -hex 32      (for SECRET_KEY, DB_PASSWORD)
#   openssl rand -base64 24   (for ADMIN_PASSWORD)
# =============================================================================

# ── Database ──
DB_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ── Application Security ──
# CRITICAL: Must be a strong random string (min 32 chars)
# Used for JWT signing — if compromised, all tokens are invalid
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── Admin Bootstrap (change password after first login!) ──
ADMIN_EMAIL=admin@CHANGE_ME_yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── SMTP (Email) ──
# Option A: Hostinger email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@CHANGE_ME_yourdomain.com
SMTP_PASSWORD=CHANGE_ME_email_password
SMTP_FROM_EMAIL=noreply@CHANGE_ME_yourdomain.com
SMTP_FROM_NAME=Lever

# Option B: Gmail SMTP (use App Password, not regular password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=your.email@gmail.com
# SMTP_FROM_NAME=Lever

# Option C: SendGrid, Mailgun, or Amazon SES
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Lever
